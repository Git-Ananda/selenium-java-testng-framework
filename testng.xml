<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM
        "https://testng.org/testng-1.0.dtd">

<suite name="Automation Suite">

    <parameter
            name="browser"
            value="edge"/>

    <listeners>

        <listener
                class-name="listeners.TestListener"/>

    </listeners>

    <test name="Login Tests">

        <classes>

            <class name="tests.LoginTest"/>

        </classes>

    </test>

</suite>