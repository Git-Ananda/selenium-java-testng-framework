<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM
        "https://testng.org/testng-1.0.dtd">

<suite
        name="Framework Suite"
        parallel="classes"
        thread-count="2">

    <parameter
            name="browser"
            value="edge"/>

    <listeners>

        <listener
                class-name="listeners.TestListener"/>

        <listener
                class-name="listeners.RetryTransformer"/>

    </listeners>

    <test name="Parallel Tests">

        <classes>

            <class name="tests.LoginTest"/>

            <class name="tests.DashboardTest"/>

        </classes>

    </test>

</suite>